# Environment
NODE_ENV=production

# Ports
HTTP_PORT=80
HTTPS_PORT=443

# Domain (required for SSL)
DOMAIN=yourdomain.com

# Email for Let's Encrypt
LETSENCRYPT_EMAIL=your-email@example.com

# Next.js specific
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_GA_ID=

# Optional: Custom env vars
# NEXT_PUBLIC_API_URL=
PROXY_API_KEY=your-openai-or-proxy-api-key
PROXY_BASE_URL=https://openai.api.proxyapi.ru/v1
PYNECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=portfolio
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
# Preferred for contact form -> Telegram notifications (separate from portfolio automation bot)
TELEGRAM_LEADS_BOT_TOKEN=your-telegram-leads-bot-token
TELEGRAM_LEADS_CHAT_ID=your-telegram-user-or-group-chat-id
# Optional thread/topic id in forum supergroup
TELEGRAM_LEADS_MESSAGE_THREAD_ID=

# Contact form (Frontend API)
DATABASE_URL=postgresql://user:password@localhost:5432/portfolio
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_EMAIL=alexandr_klychnikov@mail.ru

# Имя бота без @ — кнопка открывает tg://resolve?domain=... (приложение Telegram, без t.me в браузере).
TELEGRAM_BOT_USERNAME=
# Опционально: https://t.me/YourBot — если USERNAME не задан, имя возьмётся отсюда.
TELEGRAM_CONTACT_URL=
# Preferred contact destination for site CTA (separate from portfolio automation bot)
TELEGRAM_LEADS_BOT_USERNAME=
TELEGRAM_LEADS_CONTACT_URL=

# Testimonials: ключ для модерации отзывов (одобрение через POST /api/testimonials/moderate).
# Придумай длинный секрет или сгенерируй: openssl rand -hex 32
MODERATION_API_KEY=your-secret-moderation-key