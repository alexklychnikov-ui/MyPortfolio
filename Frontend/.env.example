# Next.js / Prisma (run from Frontend directory)
# Copy to .env and set values. For Prisma (migrate, db push) and Next.js API routes.
# If password has special chars (@ # : / %), URL-encode them (e.g. @ -> %40).

DATABASE_URL=postgresql://user:password@localhost:5432/portfolio

# Contact form API
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_EMAIL=alexandr_klychnikov@mail.ru
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Модерация отзывов: открой в браузере /moderate, введи этот ключ — список на модерации и кнопки Одобрить/Отклонить
MODERATION_API_KEY=your-secret-moderation-key

# GitHub -> AI generator (вызов только через тг-бота)
OPENAI_API_KEY=sk-xxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini
GITHUB_TOKEN=github_pat_xxxxxxxxxxxx
TELEGRAM_BACKEND_API_KEY=your-telegram-backend-secret

# Optional local proxy mode for AI (if set, proxy values are used instead of OPENAI_API_KEY)
PROXY_BASE_URL=https://openai.api.proxyapi.ru/v1
PROXY_API_KEY=sk-xxxxxxxxxxxx
