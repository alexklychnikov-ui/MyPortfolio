# Next.js / Prisma (run from Frontend directory)
# Copy to .env and set values. For Prisma (migrate, db push) and Next.js API routes.
# If password has special chars (@ # : / %), URL-encode them (e.g. @ -> %40).

DATABASE_URL=postgresql://user:password@localhost:5432/portfolio

# Contact form API
RESEND_API_KEY=re_xxxxxxxxxxxx
CONTACT_EMAIL=alexandr_klychnikov@mail.ru
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Модерация отзывов: открой в браузере /moderate, введи этот ключ — список на модерации и кнопки Одобрить/Отклонить
MODERATION_API_KEY=your-secret-moderation-key
